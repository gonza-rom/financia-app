// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoTransaccion {
  INGRESO
  GASTO
}

enum FrecuenciaRecurrente {
  DIARIO
  SEMANAL
  MENSUAL
  ANUAL
}

model Usuario {
  id            String        @id
  email         String        @unique
  nombre        String?
  moneda        String        @default("ARS")
  creadoEn      DateTime      @default(now()) @map("creado_en")
  actualizadoEn DateTime      @updatedAt @map("actualizado_en")
  transacciones Transaccion[]
  categorias    Categoria[]
  vehiculos     Vehiculo[]
  empresas  Empresa[]
  deudas        Deuda[] 

  @@map("usuarios")
}

model Categoria {
  id            String          @id @default(cuid())
  nombre        String
  icono         String          @default("circle")
  color         String          @default("#6b7280")
  tipo          TipoTransaccion
  usuarioId     String          @map("usuario_id")
  creadoEn      DateTime        @default(now()) @map("creado_en")
  actualizadoEn DateTime        @updatedAt @map("actualizado_en")
  usuario       Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacciones Transaccion[]

  @@index([usuarioId])
  @@index([usuarioId, tipo])
  @@map("categorias")
}

model Transaccion {
  id              String               @id @default(cuid())
  monto           Decimal              @db.Decimal(12, 2)
  descripcion     String
  tipo            TipoTransaccion
  fecha           DateTime
  notas           String?
  esRecurrente    Boolean              @default(false) @map("es_recurrente")
  usuarioId       String               @map("usuario_id")
  categoriaId     String               @map("categoria_id")
  creadoEn        DateTime             @default(now()) @map("creado_en")
  actualizadoEn   DateTime             @updatedAt @map("actualizado_en")
  usuario         Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria       Categoria            @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  reglaRecurrente ReglaRecurrente?
  cobroProyecto  CobroProyecto?
  gastoEmpresa   GastoEmpresa?
  gastoVehiculo   GastoVehiculo?

  @@index([usuarioId])
  @@index([usuarioId, fecha])
  @@index([usuarioId, tipo])
  @@index([usuarioId, categoriaId])
  @@map("transacciones")
}

model ReglaRecurrente {
  id            String               @id @default(cuid())
  transaccionId String               @unique @map("transaccion_id")
  frecuencia    FrecuenciaRecurrente
  proximaFecha  DateTime             @map("proxima_fecha")
  fechaFin      DateTime?            @map("fecha_fin")
  creadoEn      DateTime             @default(now()) @map("creado_en")
  transaccion   Transaccion          @relation(fields: [transaccionId], references: [id], onDelete: Cascade)

  @@map("reglas_recurrentes")
}

// ─── Módulo Vehículos ─────────────────────────────────────────────────────────

model Vehiculo {
  id            String              @id @default(cuid())
  nombre        String              // "Mi Corsa", "Moto Honda"
  marca         String
  modelo        String
  anio          Int                 @map("anio")
  patente       String?
  color         String              @default("#6b7280")
  kilometraje   Int?                @default(0)
  activo        Boolean             @default(true)
  usuarioId     String              @map("usuario_id")
  creadoEn      DateTime            @default(now()) @map("creado_en")
  actualizadoEn DateTime            @updatedAt @map("actualizado_en")
  usuario       Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  secciones     SeccionVehiculo[]   // Nafta, Seguro, GNC, etc. — configurables
  gastos        GastoVehiculo[]

  @@index([usuarioId])
  @@map("vehiculos")
}

// Secciones configurables por vehículo: Nafta, Seguro, GNC, Mantenimiento, etc.
model SeccionVehiculo {
  id            String          @id @default(cuid())
  nombre        String          // "Nafta", "Seguro", "GNC", "Mantenimiento"
  icono         String          @default("wrench")
  color         String          @default("#6b7280")
  orden         Int             @default(0)
  vehiculoId    String          @map("vehiculo_id")
  creadoEn      DateTime        @default(now()) @map("creado_en")
  actualizadoEn DateTime        @updatedAt @map("actualizado_en")
  vehiculo      Vehiculo        @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  gastos        GastoVehiculo[]

  @@index([vehiculoId])
  @@map("secciones_vehiculos")
}

model GastoVehiculo {
  id             String          @id @default(cuid())
  monto          Decimal         @db.Decimal(12, 2)
  fecha          DateTime
  descripcion    String
  notas          String?
  kilometraje    Int?            // Km al momento del gasto
  // Campos opcionales según sección
  litros         Float?          // Para nafta/GNC
  precioPorUnidad Decimal?       @db.Decimal(8, 2) @map("precio_por_unidad")
  vencimiento    DateTime?       // Para seguro
  proximoKm      Int?            @map("proximo_km") // Para service/mantenimiento
  vehiculoId     String          @map("vehiculo_id")
  seccionId      String          @map("seccion_id")
  transaccionId   String?         @unique @map("transaccion_id")  // ← campo FK
  creadoEn       DateTime        @default(now()) @map("creado_en")
  actualizadoEn  DateTime        @updatedAt @map("actualizado_en")
  vehiculo       Vehiculo        @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  seccion        SeccionVehiculo @relation(fields: [seccionId], references: [id], onDelete: Cascade)
  transaccion     Transaccion?    @relation(fields: [transaccionId], references: [id], onDelete: SetNull)

  @@index([vehiculoId])
  @@index([seccionId])
  @@index([vehiculoId, fecha])
  @@map("gastos_vehiculos")
}

model Empresa {
  id            String          @id @default(cuid())
  nombre        String
  descripcion   String?
  color         String          @default("#6b7280")
  logo          String?         // URL o emoji
  moneda        String          @default("ARS")
  activo        Boolean         @default(true)
  usuarioId     String          @map("usuario_id")
  creadoEn      DateTime        @default(now()) @map("creado_en")
  actualizadoEn DateTime        @updatedAt @map("actualizado_en")
  usuario       Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clientes      Cliente[]
  proyectos     Proyecto[]
  gastos        GastoEmpresa[]
  deudas        Deuda[]

  @@index([usuarioId])
  @@map("empresas")
}

model Cliente {
  id            String     @id @default(cuid())
  nombre        String
  email         String?
  telefono      String?
  empresaId     String     @map("empresa_id")
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")
  empresa       Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  proyectos     Proyecto[]

  @@index([empresaId])
  @@map("clientes")
}

enum EstadoProyecto {
  ACTIVO
  PAUSADO
  COMPLETADO
  CANCELADO
}

enum TipoCobroProyecto {
  UNICO
  HITOS
  SUSCRIPCION
  MIXTO
}

model Proyecto {
  id            String            @id @default(cuid())
  nombre        String
  descripcion   String?
  estado        EstadoProyecto    @default(ACTIVO)
  tipoCobro     TipoCobroProyecto @default(UNICO) @map("tipo_cobro")
  montoTotal    Decimal?          @db.Decimal(12, 2) @map("monto_total")
  empresaId     String            @map("empresa_id")
  clienteId     String?           @map("cliente_id")
  fechaInicio   DateTime?         @map("fecha_inicio")
  fechaFin      DateTime?         @map("fecha_fin")
  creadoEn      DateTime          @default(now()) @map("creado_en")
  actualizadoEn DateTime          @updatedAt @map("actualizado_en")
  empresa       Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente       Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  cobros        CobroProyecto[]

  @@index([empresaId])
  @@index([clienteId])
  @@map("proyectos")
}

enum EstadoCobro {
  PENDIENTE
  COBRADO
}

model CobroProyecto {
  id              String        @id @default(cuid())
  descripcion     String
  monto           Decimal       @db.Decimal(12, 2)
  estado          EstadoCobro   @default(PENDIENTE)
  fechaEstimada   DateTime?     @map("fecha_estimada")
  fechaCobro      DateTime?     @map("fecha_cobro")
  proyectoId      String        @map("proyecto_id")
  transaccionId   String?       @unique @map("transaccion_id")
  creadoEn        DateTime      @default(now()) @map("creado_en")
  actualizadoEn   DateTime      @updatedAt @map("actualizado_en")
  proyecto        Proyecto      @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  transaccion     Transaccion?  @relation(fields: [transaccionId], references: [id], onDelete: SetNull)

  @@index([proyectoId])
  @@map("cobros_proyecto")
}

model GastoEmpresa {
  id            String    @id @default(cuid())
  descripcion   String
  monto         Decimal   @db.Decimal(12, 2)
  fecha         DateTime
  empresaId     String    @map("empresa_id")
  transaccionId String?   @unique @map("transaccion_id")
  notas         String?
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  transaccion   Transaccion? @relation(fields: [transaccionId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@map("gastos_empresa")
}

enum TipoDeuda {
  COBRAR
  PAGAR
}

enum EstadoDeuda {
  PENDIENTE
  PAGADA
  VENCIDA
}

enum MonedaDeuda {
  ARS
  USD
  EUR
}

model Deuda {
  id               String      @id @default(cuid())
  tipo             TipoDeuda
  estado           EstadoDeuda @default(PENDIENTE)
  contraparte      String
  descripcion      String?
  moneda           MonedaDeuda @default(ARS)
  montoTotal       Decimal     @db.Decimal(12, 2) @map("monto_total")
  fechaVencimiento DateTime?   @map("fecha_vencimiento")
  fechaPago        DateTime?   @map("fecha_pago")
  usuarioId        String      @map("usuario_id")
  empresaId        String?     @map("empresa_id")
  creadoEn         DateTime    @default(now()) @map("creado_en")
  actualizadoEn    DateTime    @updatedAt @map("actualizado_en")
  usuario          Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa          Empresa?    @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  cuotas           CuotaDeuda[]
  montoPagado  Decimal     @default(0) @db.Decimal(12, 2) @map("monto_pagado")
  pagos        PagoDeuda[]

  @@index([usuarioId])
  @@index([usuarioId, tipo])
  @@index([usuarioId, estado])
  @@map("deudas")
}

model CuotaDeuda {
  id               String   @id @default(cuid())
  numero           Int
  monto            Decimal  @db.Decimal(12, 2)
  fechaVencimiento DateTime @map("fecha_vencimiento")
  fechaPago        DateTime? @map("fecha_pago")
  pagada           Boolean  @default(false)
  deudaId          String   @map("deuda_id")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")
  deuda            Deuda    @relation(fields: [deudaId], references: [id], onDelete: Cascade)

  @@index([deudaId])
  @@map("cuotas_deuda")
}

// ─── Modelo nuevo a agregar al final del schema ───────────────────────────────

model PagoDeuda {
  id          String   @id @default(cuid())
  monto       Decimal  @db.Decimal(12, 2)
  fecha       DateTime @default(now())
  notas       String?
  deudaId     String   @map("deuda_id")
  creadoEn    DateTime @default(now()) @map("creado_en")
  deuda       Deuda    @relation(fields: [deudaId], references: [id], onDelete: Cascade)

  @@index([deudaId])
  @@map("pagos_deuda")
}